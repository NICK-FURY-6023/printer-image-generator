# JWT secret - koi bhi strong random string
JWT_SECRET=your_jwt_secret_here

# Admin credentials
ADMIN_EMAIL=shreeganpatiagency.printer@admin
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here
# Hash banane ke liye run karo: node scripts/generate-hash.js 'yourPassword'

# Supabase Connection (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
# Optional: service_role key (for admin operations)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
